OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
TAVILY_API_KEY=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
LANGSMITH_TRACING=

# Internal compliance assistant defaults
# Keep external search disabled for confidential internal questions unless explicitly approved.
EXTERNAL_SEARCH_ALLOWED=false
SEARCH_API=none
ASSISTANT_NAME=Siemens Healthineers Compliance Assistant
ORGANIZATION_NAME=Siemens Healthineers
BUSINESS_REGION=Unspecified
COMPLIANCE_SCOPE=medical technology compliance, healthcare compliance, internal policies, privacy, quality, anti-corruption, procurement, marketing, and interactions with healthcare professionals

# Point this to a local folder containing approved internal policy files.
# Supported MVP file types: .md, .txt, .pdf
INTERNAL_KNOWLEDGE_BASE_PATH=
INTERNAL_SEARCH_FILE_GLOBS=*.md,*.txt,*.pdf
INTERNAL_SEARCH_MAX_RESULTS=5
INTERNAL_SEARCH_CHUNK_CHARS=3500

# Optional indexed QMS evidence store used by the Compliance Reviewer graph and ISO/QMS tools.
OFFICIAL_DOCS_PATH=./data/official_docs
INTERNAL_DOCS_PATH=./data/internal_docs
COMPLIANCE_INDEX_PATH=./data/compliance_index
EVIDENCE_REQUIRED=true

# Only necessary for Open Agent Platform
SUPABASE_KEY=
SUPABASE_URL=
# Should be set to true for a production deployment on Open Agent Platform. Should be set to false otherwise, such as for local development.
GET_API_KEYS_FROM_CONFIG=false
